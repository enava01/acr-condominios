GEMINI_API_KEY=your_gemini_api_key_here
API_BASE_URL=http://localhost:8000

# Google Cloud Storage — almacenamiento persistente de expedientes
# Deja vacío para usar archivo local (desarrollo sin GCS)
GCS_BUCKET_NAME=

# Ruta al archivo JSON de credenciales de la cuenta de servicio GCP
# Solo necesario en desarrollo local cuando GCS_BUCKET_NAME está configurado
# En Cloud Run las credenciales se inyectan automáticamente
GCP_KEY_FILE=/ruta/a/tu/service-account-key.json
